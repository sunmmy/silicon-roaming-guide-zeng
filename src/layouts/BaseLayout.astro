---
interface Props {
  title?: string;
  description?: string;
}

import "../styles/global.css";

const {
  title = "个人网站",
  description = "个人介绍、项目作品与长期积累。",
} = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header" aria-label="主导航">
        <a class="brand" href="/" aria-label="回到首页">
          <span class="brand-mark">P</span>
          <span>Personal Site</span>
        </a>
        <nav class="nav-links">
          <a href="/projects">项目</a>
          <a href="/about">关于</a>
          <a href="mailto:you@example.com">联系</a>
        </nav>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <span>© 2026 你的名字</span>
        <span>Built as a quiet, durable personal archive.</span>
      </footer>
    </div>
  </body>
</html>
